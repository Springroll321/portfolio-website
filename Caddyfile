patricktech.site, www.patricktech.site {
    root * /usr/share/caddy
    
    # Force 200 OK by stripping Range headers from the request
    # and stripping Accept-Ranges/ETag from the response.
    # This fixes the "Partial Content" corruption on EC2/Docker.
    request_header -Range
    header -Accept-Ranges
    header -ETag
    header Cache-Control "no-cache, no-store, must-revalidate"

    file_server
    encode gzip

    # SPA support: if the file doesn't exist, serve index.html
    try_files {path} /index.html

    # Cache headers for static assets
    @static {
        path /assets/* /css/* /js/*
    }
    header @static Cache-Control "public, max-age=31536000, no-transform"

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer-when-downgrade
        Strict-Transport-Security max-age=31536000;
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
    }
}
